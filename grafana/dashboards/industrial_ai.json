{
  "id": null,
  "uid": "industrial-ai-v1",
  "title": "Industrial AI — Asset Monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["industrial", "predictive-maintenance"],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Current Risk Score by Asset",
      "type": "bargauge",
      "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "minVizWidth": 0
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
          "rawSql": "SELECT asset_id AS metric, risk_score AS value FROM dbo.asset_risk_current ORDER BY asset_id",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Risk Level by Asset",
      "type": "table",
      "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
          "rawSql": "SELECT asset_id, risk_level, risk_score, failure_mode, top_drivers, as_of_minute_ts AS last_updated FROM dbo.asset_risk_current ORDER BY risk_score DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg Temperature (°C) per Asset per Minute",
      "type": "timeseries",
      "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 88 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
          "rawSql": "SELECT minute_ts AS time, asset_id AS metric, avg_temp_c AS value FROM dbo.asset_minute_fact WHERE $__timeFilter(minute_ts) ORDER BY minute_ts",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Vibration (mm/s) per Asset per Minute",
      "type": "timeseries",
      "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "velocityms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 7 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
          "rawSql": "SELECT minute_ts AS time, asset_id AS metric, avg_vib_mm_s AS value FROM dbo.asset_minute_fact WHERE $__timeFilter(minute_ts) ORDER BY minute_ts",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Risk Score Over Time",
      "type": "timeseries",
      "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
          "rawSql": "SELECT minute_ts AS time, asset_id AS metric, risk_score AS value FROM dbo.asset_risk_minute WHERE $__timeFilter(minute_ts) ORDER BY minute_ts",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Anomaly Events",
      "type": "table",
      "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "mssql", "uid": "industrial-ai-mssql" },
          "rawSql": "SELECT TOP 50 asset_id, minute_ts, anomaly_type, signal, severity, score, reason FROM dbo.asset_anomaly_events WHERE $__timeFilter(minute_ts) ORDER BY minute_ts DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
